{
  "name": "tuurosung/switch8583",
  "description": "A clean, well-tested ISO 8583 message library for PHP: construction, parsing, and validation for the 1987 and 1993 standard versions, with BCD/ASCII encoding, LLVAR/LLLVAR fields, and dual bitmaps.",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "iso8583",
    "iso-8583",
    "iso 8583",
    "payments",
    "fintech",
    "payment-switch",
    "switching",
    "acquiring",
    "issuing",
    "emv",
    "pos",
    "bcd",
    "bitmap",
    "ghipss",
    "laravel"
  ],
  "authors": [
    {
      "name": "Shahabdeen Abdul-Moomin",
      "homepage": "https://github.com/tuurosung"
    }
  ],
  "support": {
    "issues": "https://github.com/tuurosung/switch8583/issues",
    "source": "https://github.com/tuurosung/switch8583"
  },
  "require": {
    "php": "^8.1",
    "ext-mbstring": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "phpstan/phpstan": "^2.0",
    "friendsofphp/php-cs-fixer": "^3.64"
  },
  "suggest": {
    "illuminate/support": "Enables the optional Laravel service provider (Iso8583ServiceProvider) and config publishing."
  },
  "autoload": {
    "psr-4": {
      "Tuurosung\\switch8583\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tuurosung\\switch8583\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Tuurosung\\switch8583\\Laravel\\Iso8583ServiceProvider"
      ]
    }
  },
  "scripts": {
    "test": "phpunit",
    "test:unit": "phpunit --testsuite Unit",
    "test:integration": "phpunit --testsuite Integration",
    "analyse": "phpstan analyse",
    "lint": "php-cs-fixer fix --dry-run --diff",
    "fix": "php-cs-fixer fix",
    "check": [
      "@lint",
      "@analyse",
      "@test"
    ]
  },
  "config": {
    "sort-packages": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}