{
    "name": "tuurosung/iso8583",
    "description": "A clean, well-tested ISO 8583 message library for PHP, designed for the construction, parsing, and validation of the 1987 and 1993 standard versions.",
    "type": "library",
    "license": "MIT",
    "keywords": ["iso8583", "iso-8583", "payments", "fintech", "payment-switch", "emv", "pos", "acquiring"],
    "authors": [
        { "name": "Shahabdeen Abdul-Moomin", "homepage": "https://github.com/tuurosung" }
    ],
    "require": {
        "php": "^8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Tuurosung\\switch8583\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tuurosung\\switch8583\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}